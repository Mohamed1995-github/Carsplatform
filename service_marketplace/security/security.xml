<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Service Marketplace Groups -->
        <record id="group_service_marketplace_user" model="res.groups">
            <field name="name">Service Marketplace User</field>
            <field name="category_id" ref="base.module_category_services"/>
            <field name="comment">Can view and create service providers</field>
        </record>

        <record id="group_service_marketplace_manager" model="res.groups">
            <field name="name">Service Marketplace Manager</field>
            <field name="category_id" ref="base.module_category_services"/>
            <field name="implied_ids" eval="[(4, ref('group_service_marketplace_user'))]"/>
            <field name="comment">Can manage all service providers and approve registrations</field>
        </record>

        <!-- Service Provider Portal Group -->
        <record id="group_service_provider_portal" model="res.groups">
            <field name="name">Service Provider Portal</field>
            <field name="category_id" ref="base.module_category_portal"/>
            <field name="implied_ids" eval="[(4, ref('base.group_portal'))]"/>
            <field name="comment">Portal access for service providers</field>
        </record>
    </data>
</odoo>


