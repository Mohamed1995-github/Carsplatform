<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Service Provider Tree View -->
    <record id="view_service_provider_tree" model="ir.ui.view">
        <field name="name">service.provider.tree</field>
        <field name="model">service.provider</field>
        <field name="arch" type="xml">
            <tree string="Service Providers" decoration-info="status=='draft'" 
                  decoration-warning="status=='verification'" 
                  decoration-success="status=='registered'"
                  decoration-danger="status in ['suspended', 'refused']">
                <field name="ref"/>
                <field name="name"/>
                <field name="provider_phone"/>
                <field name="nni"/>
                <field name="status" widget="badge"/>
                <field name="contract_start_date"/>
                <field name="contract_expiry_date"/>
                <field name="service_domain_ids" widget="many2many_tags"/>
                <field name="partner_id"/>
                <field name="user_id"/>
            </tree>
        </field>
    </record>

    <!-- Service Provider Form View -->
    <record id="view_service_provider_form" model="ir.ui.view">
        <field name="name">service.provider.form</field>
        <field name="model">service.provider</field>
        <field name="arch" type="xml">
            <form string="Service Provider">
                <header>
                    <button name="action_verify" string="Send for Verification" 
                            type="object" class="btn-primary" 
                            attrs="{'invisible': [('status', '!=', 'draft')]}"/>
                    <button name="action_register" string="Register" 
                            type="object" class="btn-primary" 
                            attrs="{'invisible': [('status', '!=', 'verification')]}"/>
                    <button name="action_suspend" string="Suspend" 
                            type="object" class="btn-warning" 
                            attrs="{'invisible': [('status', 'not in', ['registered'])]}"/>
                    <button name="action_refuse" string="Refuse" 
                            type="object" class="btn-danger" 
                            attrs="{'invisible': [('status', 'not in', ['verification'])]}"/>
                    <button name="action_reset_to_draft" string="Reset to Draft" 
                            type="object" class="btn-secondary" 
                            attrs="{'invisible': [('status', 'not in', ['suspended', 'refused'])]}"/>
                    <field name="status" widget="statusbar" statusbar_visible="draft,verification,registered"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="%(action_service_provider_kanban)d" type="action" 
                                class="oe_stat_button" icon="fa-th-large">
                            <field name="id" widget="statinfo" string="Kanban"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Service Provider Name"/>
                        </h1>
                        <h3>
                            <field name="ref" readonly="1"/>
                        </h3>
                    </div>
                    <group>
                        <group name="basic_info" string="Basic Information">
                            <field name="provider_phone" required="1"/>
                            <field name="nni" required="1"/>
                            <field name="recommender_phone"/>
                        </group>
                        <group name="contract_info" string="Contract Information">
                            <field name="contract_start_date" required="1"/>
                            <field name="contract_expiry_date" required="1"/>
                        </group>
                    </group>
                    <group>
                        <group name="ranks" string="Ranks">
                            <field name="supplier_rank"/>
                            <field name="service_provider_rank"/>
                        </group>
                        <group name="related_records" string="Related Records">
                            <field name="partner_id" readonly="1"/>
                            <field name="user_id" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Service Domains" name="service_domains">
                            <field name="service_domain_ids" widget="many2many_tags" 
                                   options="{'color_field': 'color', 'no_create': True}"/>
                        </page>
                        <page string="Services" name="services">
                            <field name="service_ids" widget="many2many_tags" 
                                   options="{'no_create': True}"/>
                        </page>
                        <page string="Related Contact" name="contact" attrs="{'invisible': [('partner_id', '=', False)]}">
                            <field name="partner_id" readonly="1">
                                <form>
                                    <group>
                                        <group>
                                            <field name="name"/>
                                            <field name="phone"/>
                                            <field name="email"/>
                                        </group>
                                        <group>
                                            <field name="street"/>
                                            <field name="city"/>
                                            <field name="zip"/>
                                            <field name="country_id"/>
                                        </group>
                                    </group>
                                </form>
                            </field>
                        </page>
                        <page string="Portal User" name="portal_user" attrs="{'invisible': [('user_id', '=', False)]}">
                            <field name="user_id" readonly="1">
                                <form>
                                    <group>
                                        <field name="name"/>
                                        <field name="login"/>
                                        <field name="active"/>
                                        <field name="groups_id" widget="many2many_tags"/>
                                    </group>
                                </form>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Service Provider Search View -->
    <record id="view_service_provider_search" model="ir.ui.view">
        <field name="name">service.provider.search</field>
        <field name="model">service.provider</field>
        <field name="arch" type="xml">
            <search string="Search Service Providers">
                <field name="name"/>
                <field name="ref"/>
                <field name="provider_phone"/>
                <field name="nni"/>
                <field name="partner_id"/>
                <field name="user_id"/>
                <separator/>
                <filter string="Draft" name="draft" domain="[('status', '=', 'draft')]"/>
                <filter string="Verification" name="verification" domain="[('status', '=', 'verification')]"/>
                <filter string="Registered" name="registered" domain="[('status', '=', 'registered')]"/>
                <filter string="Suspended" name="suspended" domain="[('status', '=', 'suspended')]"/>
                <filter string="Refused" name="refused" domain="[('status', '=', 'refused')]"/>
                <separator/>
                <filter string="With Portal User" name="with_portal_user" domain="[('user_id', '!=', False)]"/>
                <filter string="Without Portal User" name="without_portal_user" domain="[('user_id', '=', False)]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter string="Status" name="group_status" context="{'group_by': 'status'}"/>
                    <filter string="Service Domain" name="group_domain" context="{'group_by': 'service_domain_ids'}"/>
                    <filter string="Creation Date" name="group_create_date" context="{'group_by': 'create_date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Service Provider Kanban View -->
    <record id="view_service_provider_kanban" model="ir.ui.view">
        <field name="name">service.provider.kanban</field>
        <field name="model">service.provider</field>
        <field name="arch" type="xml">
            <kanban default_group_by="status" class="o_kanban_small_column">
                <field name="status"/>
                <field name="name"/>
                <field name="ref"/>
                <field name="provider_phone"/>
                <field name="service_domain_ids"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <div class="oe_kanban_content">
                                <div class="o_kanban_record_top">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title">
                                            <field name="name"/>
                                        </strong>
                                        <div class="o_kanban_record_subtitle">
                                            <field name="ref"/>
                                        </div>
                                    </div>
                                </div>
                                <div class="o_kanban_record_body">
                                    <div>
                                        <i class="fa fa-phone"/> <field name="provider_phone"/>
                                    </div>
                                    <div>
                                        <field name="service_domain_ids" widget="many2many_tags" 
                                               options="{'color_field': 'color', 'no_create': True}"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Service Provider Action -->
    <record id="action_service_provider" model="ir.actions.act_window">
        <field name="name">Service Providers</field>
        <field name="res_model">service.provider</field>
        <field name="view_mode">tree,form,kanban</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first Service Provider!
            </p>
            <p>
                Service providers can be registered and managed through this interface.
                They will automatically get portal access when their status becomes 'Registered'.
            </p>
        </field>
    </record>

    <!-- Service Provider Kanban Action -->
    <record id="action_service_provider_kanban" model="ir.actions.act_window">
        <field name="name">Service Providers</field>
        <field name="res_model">service.provider</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="context">{}</field>
    </record>

    <!-- Menu Items -->
    <menuitem id="menu_service_marketplace_root" 
              name="Service Marketplace" 
              sequence="10"/>

    <menuitem id="menu_service_providers" 
              name="Service Providers" 
              parent="menu_service_marketplace_root" 
              action="action_service_provider" 
              sequence="10"/>

</odoo>


